{
  "name": "modern-timesheet-tracker",
  "version": "2.0.0",
  "description": "A modern, cross-platform timesheet tracking application built with Tauri and Svelte",
  "main": "index.js",
  "scripts": {
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
